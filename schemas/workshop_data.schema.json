{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/agroqirax/timberborn-schemas/main/schemas/workshop_data.schema.json",
  "title": "Workshop data",
  "description": "Workshop data for steam workshop",
  "type": "object",
  "properties": {
    "ItemId": {
      "type": "string",
      "description": "Steam workshop ID",
      "examples": ["3275060459"],
      "pattern": "^[0-9]{10}$"
    },
    "Name": {
      "type": "string",
      "description": "Steam workshop name",
      "minLength": 1,
      "examples": ["Shanty Speaker"]
    },
    "Visibility": {
      "type": "string",
      "description": "Steam workshop visibility level",
      "enum": ["Public", "Friends-only", "Private", "Unlisted"],
      "default": "Public"
    },
    "UpdateDescription": {
      "type": "boolean",
      "description": "Update description when updating mod",
      "default": true
    },
    "UpdateVisibility": {
      "type": "boolean",
      "description": "Update visibility when updating mod",
      "default": true
    },
    "UpdatePreview": {
      "type": "boolean",
      "description": "Update thumbnail when updating mod",
      "default": true
    },
    "UpdateTags": {
      "type": "boolean",
      "description": "Update tags when updating mod",
      "default": true
    },
    "Tags": {
      "type": "array",
      "uniqueItems": true,
      "description": "List of tags",
      "items": {
        "type": "string",
        "description": "Tag",
        "examples": [
          "Update 1.0",
          "Update 0.7",
          "Update 0.6",
          "New content",
          "Quality of life",
          "Balance",
          "Cheats",
          "Visuals",
          "Modding tools",
          "Other",
          "Buildings",
          "Plants",
          "Goods",
          "Factions",
          "Outfits",
          "Decals",
          "Translations",
          "Miscellaneous"
        ]
      }
    }
  },
  "required": [
    "ItemId",
    "Name",
    "Visibility",
    "UpdateDescription",
    "UpdateVisibility",
    "UpdatePreview",
    "UpdateTags",
    "Tags"
  ],
  "additionalProperties": false
}
